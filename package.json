{
    "name": "workspace-root",
    "version": "0.0.0",
    "private": true,
    "description": "POC to figure out Tanstack Start limitations with our tech stack",
    "type": "module",
    "scripts": {
        "dev-web": "turbo run dev --filter=@apps/web",
        "dev-storybook-demo": "turbo run dev --filter=@apps/storybook-demo",
        "dev-storybook-intent-ui": "turbo run dev --filter=@apps/storybook-intent-ui",
        "build-web": "turbo run build --filter=@apps/web",
        "build-storybook-demo": "turbo run build-storybook --filter=@apps/storybook-demo",
        "build-storybook-intent-ui": "turbo run build-storybook --filter=@apps/storybook-intent-ui",
        "serve-storybook-demo": "turbo run serve-storybook --filter=@apps/storybook-demo",
        "serve-storybook-intent-ui": "turbo run serve-storybook --filter=@apps/storybook-intent-ui",
        "deploy-web": "turbo run deploy --filter=@apps/web",
        "lint": "turbo run lint --continue",
        "typecheck": "tsgo",
        "oxlint": "oxlint --deny-warnings",
        "oxfmt": "oxfmt",
        "knip": "knip",
        "syncpack": "syncpack lint",
        "clean": "pnpm -r --parallel --include-workspace-root exec pnpm dlx rimraf dist storybook-static .turbo .netlify .tanstack node_modules/.cache node_modules/.vite node_modules/.vite-temp",
        "reset": "pnpm run --sequential \"/^reset:.*/\"",
        "reset:clean": "pnpm clean",
        "reset:delete-node-modules": "pnpm -r --parallel --include-workspace-root exec pnpm dlx rimraf node_modules pnpm-lock.yaml",
        "list-outdated-deps": "pnpm outdated -r --format list",
        "update-outdated-deps": "pnpm run --sequential \"/^update-outdated-deps:.*/\"",
        "update-outdated-deps:update-versions": "pnpm update -r --latest",
        "update-outdated-deps:update-peers": "syncpack fix"
    },
    "devDependencies": {
        "@packages/ts-configs": "workspace:*",
        "@types/node": "25.6.0",
        "@typescript/native-preview": "7.0.0-dev.20260421.2",
        "knip": "6.6.0",
        "oxfmt": "0.46.0",
        "oxlint": "1.61.0",
        "syncpack": "14.3.0",
        "turbo": "2.9.6",
        "typescript": "6.0.3"
    },
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=10"
    },
    "packageManager": "pnpm@10.30.1"
}
