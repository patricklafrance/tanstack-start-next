{
    "$schema": "./node_modules/turbo/schema.json",
    "ui": "tui",
    "tasks": {
        "transit": {
            "dependsOn": ["^transit"],
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        // "build": {
        //     "dependsOn": ["^build"],
        //     "inputs": ["$TURBO_DEFAULT$", "!**/README.md", "!**/CLAUDE.md"],
        //     "env": ["MODULES"],
        //     "outputs": ["dist/**"]
        // },
        // "build-storybook": {
        //     "cache": false
        // },
        "serve-build": {
            "dependsOn": ["build"],
            "cache": false,
            "persistent": true
        },
        // "serve-storybook": {
        //     "dependsOn": ["build-storybook"],
        //     "cache": false,
        //     "persistent": true
        // },
        "lint": {
            "dependsOn": ["//#oxlint", "//#oxfmt", "typecheck", "//#typecheck", "//#syncpack", "//#knip"]
        },
        "//#knip": {
            "inputs": ["$TURBO_DEFAULT$", "knip.json", "!**/README.md", "!**/CLAUDE.md"],
            "outputs": []
        },
        "//#oxlint": {
            "inputs": ["$TURBO_DEFAULT$", "!**/README.md", "!**/CLAUDE.md"],
            "outputs": []
        },
        "//#oxfmt": {
            "inputs": ["$TURBO_DEFAULT$", "!**/README.md", "!**/CLAUDE.md"],
            "outputs": []
        },
        "//#typecheck": {
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "test/**/*.tsx", "tsconfig.json", "!apps", "!packages"],
            "outputs": ["node_modules/.cache/tsbuildinfo.json"]
        },
        "typecheck": {
            "dependsOn": ["transit"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "test/**/*.tsx", "tsconfig.json", "tsconfig.build.json"],
            "outputs": ["node_modules/.cache/tsbuildinfo.json"]
        },
        "//#syncpack": {
            "inputs": [".syncpackrc.js", "package.json", "packages/**/package.json", "apps/**/package.json", "modules/**/package.json"]
        }
    }
}
